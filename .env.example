# HTTP
APP_PORT=3000

# PostgreSQL - fictitious local credentials
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wa_orchestrator_example

# OpenAI - replace only in a private .env
OPENAI_API_KEY=replace_with_openai_api_key
DEFAULT_OPENAI_MODEL=gpt-5.4-mini
OPENAI_REQUEST_TIMEOUT_MS=10000
IPDE_UNDERSTANDING_MODEL=
IPDE_UNDERSTANDING_PROMPT_VERSION=v1
IPDE_TOPIC_GENERATION_MODEL=
IPDE_TOPIC_GENERATION_PROMPT_VERSION=v1
IPDE_TOPIC_GENERATION_MAX_ATTEMPTS=2
IPDE_WHATSAPP_TEXT_CHUNK_MAX_CHARS=3000
IPDE_COMMERCIAL_CONFIG_PATH=./config/ipde/commercial-config.json
IPDE_MODEL_PDF_ASSETS_PATH=./config/ipde/model-pdf-assets.json
IPDE_PRICING_PROMOTIONS_PATH=./config/ipde/pricing-promotions.json
IPDE_MEDIA_ASSETS_PATH=./config/ipde/media-assets.json
IPDE_MEDIA_STORAGE_SUBDIR=ipde-media
IPDE_WHATSAPP_PHONE_ID=replace_with_ipde_whatsapp_phone_number_id
IPDE_WHATSAPP_DRY_RUN_PAYLOAD_LOG=false
IPDE_OUTBOUND_MAX_ATTEMPTS=3
IPDE_OUTBOUND_RETRY_DELAY_SECONDS=60

# WhatsApp Cloud API - sending remains disabled in this example
META_APP_SECRET=replace_with_meta_app_secret
WHATSAPP_WEBHOOK_SIGNATURE_VALIDATION_ENABLED=false
WHATSAPP_VERIFY_TOKEN=replace_with_webhook_verify_token
WHATSAPP_ACCESS_TOKEN=replace_with_meta_access_token
WHATSAPP_API_VERSION=v21.0
WHATSAPP_SEND_ENABLED=false
WHATSAPP_REQUEST_TIMEOUT_MS=10000

# IPDE catalog
IPDE_TENANT_CODE=IPDE
IPDE_MANUAL_CATALOG_PATH=./config/ipde/catalog.manual.json
PERSISTENT_DATA_DIR=./data
IPDE_GENERATED_CATALOG_SUBDIR=generated-catalog

# Railway supplies this value when a volume is mounted. PERSISTENT_DATA_DIR,
# when explicitly configured, has priority.
# RAILWAY_VOLUME_MOUNT_PATH=/path/to/example/railway-volume
