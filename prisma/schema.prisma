// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  INTERESTED
  FOLLOW_UP
  WON
  LOST
  HUMAN_REQUIRED
}

enum MessageRole {
  USER
  ASSISTANT
  HUMAN
  SYSTEM
}

enum PredefinedResponseMatchType {
  KEYWORD
  INTENT
  DEFAULT
}

enum IpdeConversationStage {
  NEW
  UNDERSTANDING_REQUEST
  WAITING_FOR_SUBJECT
  TOPIC_LIST_READY
  WAITING_FOR_TOPIC_SELECTION
  TOPICS_SELECTED
  WAITING_FOR_PRODUCT_TYPE
  WAITING_FOR_ISSUER_VARIANT
  WAITING_FOR_FULL_NAME
  WAITING_FOR_ORDER_CONFIRMATION
  WAITING_FOR_PAYMENT
  PAYMENT_UNDER_REVIEW
  HUMAN_TAKEOVER
  READY_FOR_ISSUANCE
  COMPLETED
}

enum IpdeAutomationMode {
  ACTIVE
  PAUSED_HUMAN
  DISABLED
}

enum IpdeOrderStatus {
  DRAFT
  AWAITING_CONFIRMATION
  CONFIRMED
  AWAITING_PAYMENT
  PAYMENT_UNDER_REVIEW
  READY_FOR_ISSUANCE
  COMPLETED
  CANCELLED
}

enum IpdePaymentStatus {
  NOT_REQUESTED
  AWAITING_PROOF
  PROOF_RECEIVED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum IpdeSubjectRequestStatus {
  REQUESTED
  LIST_PRESENTED
  SELECTION_COMPLETE
  CANCELLED
}

enum IpdeOrderItemStatus {
  DRAFT
  CONFIRMED
  REMOVED
}

model Tenant {
  id              String       @id @default(uuid())
  name            String
  businessType    String
  whatsappPhoneId String       @unique
  status          TenantStatus @default(ACTIVE)

  agentConfig   AgentConfig?
  leads         Lead[]
  conversations Conversation[]
  usageDaily    UsageDaily[]

  predefinedResponses PredefinedResponse[]
  knowledgeItems      KnowledgeItem[]

  ipdeConversationStates IpdeConversationState[]
  ipdeOrders             IpdeOrder[]
  ipdeSubjectRequests    IpdeSubjectRequest[]
  ipdeOrderItems         IpdeOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentConfig {
  id       String @id @default(uuid())
  tenantId String @unique

  tone              String
  objective         String
  businessInfo      String
  services          String
  fixedRules        String
  humanHandoffRules String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id       String     @id @default(uuid())
  tenantId String
  phone    String
  name     String?
  interest String?
  status   LeadStatus @default(NEW)
  score    Int        @default(0)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  ipdeConversationStates IpdeConversationState[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, status])
}

model Conversation {
  id       String @id @default(uuid())
  tenantId String
  leadId   String

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages Message[]

  ipdeConversationState IpdeConversationState?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([leadId])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  externalId     String?     @unique
  tokensInput    Int         @default(0)
  tokensOutput   Int         @default(0)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

model UsageDaily {
  id       String   @id @default(uuid())
  tenantId String
  date     DateTime

  inboundMessages Int     @default(0)
  aiResponses     Int     @default(0)
  tokensInput     Int     @default(0)
  tokensOutput    Int     @default(0)
  estimatedCost   Decimal @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, date])
  @@index([tenantId])
}

model PredefinedResponse {
  id            String                      @id @default(uuid())
  tenantId      String
  name          String
  matchType     PredefinedResponseMatchType @default(KEYWORD)
  keywords      String[]                    @default([])
  intent        String?
  response      String
  priority      Int                         @default(100)
  isActive      Boolean                     @default(true)
  requiresHuman Boolean                     @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, isActive])
  @@index([tenantId, matchType])
}

model KnowledgeItem {
  id       String @id @default(uuid())
  tenantId String

  title    String
  content  String
  category String?
  isActive Boolean @default(true)
  priority Int     @default(100)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, isActive])
  @@index([tenantId, category])
}

model IpdeConversationState {
  id               String                @id @default(uuid())
  tenantId         String
  leadId           String
  conversationId   String                @unique
  stage            IpdeConversationStage @default(NEW)
  automationMode   IpdeAutomationMode    @default(ACTIVE)
  pauseReason      String?
  pausedAt         DateTime?
  resumedAt        DateTime?
  stateVersion     Int                   @default(1)
  lastTransitionAt DateTime              @default(now())
  activeOrderId    String?               @unique

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  orders       IpdeOrder[]  @relation("IpdeStateOrders")
  activeOrder  IpdeOrder?   @relation("IpdeActiveOrder", fields: [activeOrderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, stage])
  @@index([tenantId, automationMode])
  @@index([leadId])
}

model IpdeOrder {
  id                  String            @id @default(uuid())
  tenantId            String
  conversationStateId String
  status              IpdeOrderStatus   @default(DRAFT)
  paymentStatus       IpdePaymentStatus @default(NOT_REQUESTED)
  fullName            String?
  normalizedFullName  String?
  fullNameConfirmedAt DateTime?
  currencyCode        String            @default("PEN")
  quotedAmount        Decimal?          @db.Decimal(12, 2)
  quoteConfirmedAt    DateTime?
  confirmedAt         DateTime?
  readyForIssuanceAt  DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?

  tenant            Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationState IpdeConversationState  @relation("IpdeStateOrders", fields: [conversationStateId], references: [id], onDelete: Cascade)
  activeForState    IpdeConversationState? @relation("IpdeActiveOrder")
  subjectRequests   IpdeSubjectRequest[]
  items             IpdeOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([conversationStateId, createdAt])
  @@index([paymentStatus])
}

model IpdeSubjectRequest {
  id                   String                   @id @default(uuid())
  tenantId             String
  orderId              String
  categoryCode         String?
  catalogEntryId       String?
  displayName          String
  normalizedName       String
  catalogSource        String?
  status               IpdeSubjectRequestStatus @default(REQUESTED)
  listPresentedAt      DateTime?
  selectionCompletedAt DateTime?

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  IpdeOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items  IpdeOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId, normalizedName])
  @@index([tenantId, normalizedName])
  @@index([orderId, status])
}

model IpdeOrderItem {
  id                  String              @id @default(uuid())
  tenantId            String
  orderId             String
  subjectRequestId    String?
  catalogTopicId      String?
  topicName           String
  normalizedTopicName String
  productTypeCode     String?
  issuerCode          String?
  issuerVariantCode   String?
  status              IpdeOrderItemStatus @default(DRAFT)
  confirmedAt         DateTime?
  removedAt           DateTime?

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order          IpdeOrder           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subjectRequest IpdeSubjectRequest? @relation(fields: [subjectRequestId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId, normalizedTopicName])
  @@index([tenantId, status])
  @@index([orderId])
  @@index([subjectRequestId])
}
